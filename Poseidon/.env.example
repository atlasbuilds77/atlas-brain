# Poseidon Environment Variables
# Copy this to .env and fill in your actual keys

# OpenAI (for TradingAgents)
OPENAI_API_KEY=your_openai_api_key_here

# Alpha Vantage (for market data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Polygon.io (for options data - optional)
POLYGON_API_KEY=your_polygon_key_here

# Broker API keys (for live trading - TBD)
BROKER_API_KEY=your_broker_key_here
BROKER_API_SECRET=your_broker_secret_here

# Database (if using - optional)
DATABASE_URL=postgresql://user:pass@localhost/poseidon
