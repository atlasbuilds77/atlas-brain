# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# Clawdbot Configuration
CLAWDBOT_URL=http://localhost:3000
CLAWDBOT_TOKEN=

# Model (haiku for cheap)
MODEL=anthropic/claude-haiku-3.5

# Optional: Comma-separated channel IDs to listen in
# Leave empty to listen in all channels
ALLOWED_CHANNELS=

# Optional: Prefix for bot responses
RESPONSE_PREFIX=
