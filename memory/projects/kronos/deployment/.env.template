# =====================================================
# KRONOS ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =====================================================

# ---------------------
# Application Settings
# ---------------------
APP_NAME=Kronos
APP_ENV=development  # development | staging | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
LOG_LEVEL=INFO

# ---------------------
# Database (PostgreSQL)
# ---------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=kronos
DB_USER=kronos
DB_PASSWORD=change-this-password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ---------------------
# Redis
# ---------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1

# ---------------------
# Storage (S3/MinIO)
# ---------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=kronos_minio_dev
S3_SECRET_KEY=kronos_minio_secret_dev
S3_BUCKET=kronos-files
S3_REGION=us-east-1

# For production AWS S3:
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key

# ---------------------
# Email (SendGrid)
# ---------------------
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@kronos.app
EMAIL_FROM_NAME=Kronos

# IMAP for email ingestion
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# ---------------------
# SMS (Twilio)
# ---------------------
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ---------------------
# AI/ML APIs
# ---------------------
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------
# Monitoring & Logging
# ---------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ENVIRONMENT=${APP_ENV}
SENTRY_TRACES_SAMPLE_RATE=0.1

# LogRocket (frontend)
LOGROCKET_APP_ID=your-logrocket-app-id

# ---------------------
# Security
# ---------------------
# JWT Configuration
JWT_SECRET_KEY=${SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.kronos.io

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Encryption (for file storage)
ENCRYPTION_KEY=your-32-byte-encryption-key

# ---------------------
# Client Configuration (Laura Pilot)
# ---------------------
CLIENT_ID=laura-tax
CLIENT_NAME=Laura's Tax Practice
CLIENT_DOMAIN=laura.kronos.app
CLIENT_INDUSTRY=tax

# ---------------------
# Feature Flags
# ---------------------
FEATURE_AI_LEAD_SCORING=true
FEATURE_EMAIL_CATEGORIZATION=true
FEATURE_DAILY_DIGEST=true
FEATURE_TAX_ORGANIZERS=true
FEATURE_RETENTION_PREDICTION=false

# ---------------------
# Daily Digest Settings
# ---------------------
DIGEST_TIME=06:00  # 6 AM local time
DIGEST_TIMEZONE=America/Los_Angeles

# ---------------------
# Compliance (WISP)
# ---------------------
DATA_RETENTION_YEARS=3
AUDIT_LOG_ENABLED=true
ENCRYPTION_AT_REST=true
